# Copie para .env e ajuste conforme necessário. NÃO comite o .env real.

# Banco
DB_NAME=trcon_site
DB_USERNAME=trcon
DB_PASSWORD=trcon
DB_PORT=5432

# Backend
BACKEND_PORT=8081
SPRING_PROFILES_ACTIVE=dev

# CORS: origem do frontend permitida
TRCON_CORS_ALLOWED_ORIGINS=http://localhost:5500

# API interna (Sirius Marketing -> site backend)
TRCON_SITE_INTERNAL_API_KEY=dev-internal-key-change-me
