# Copie para .env e ajuste conforme necessário. NÃO comite o .env real.

# Banco (porta 5434 quando 5432 está ocupada por outro projeto)
DB_NAME=trcon_site
DB_USERNAME=trcon
DB_PASSWORD=trcon
DB_PORT=5434
DB_URL=jdbc:postgresql://localhost:5434/trcon_site

# Backend
BACKEND_PORT=8081
SPRING_PROFILES_ACTIVE=dev

# CORS: origem do frontend (Vite dev server)
TRCON_CORS_ALLOWED_ORIGINS=http://localhost:4173,http://127.0.0.1:4173

# API interna (Sirius Marketing -> site backend)
TRCON_SITE_INTERNAL_API_KEY=dev-internal-key-change-me
